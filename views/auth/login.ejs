<section class="cn-section">
  <div class="cn-section-header">
    <h2>Login</h2>
  </div>

  <form class="cn-form" action="/auth/login" method="POST">
    <label class="cn-label">Email</label>
    <input class="cn-input" name="email" type="email" placeholder="you@example.com" required />

    <label class="cn-label">Password</label>
    <input class="cn-input" name="password" type="password" placeholder="••••••••" required />

    <button class="cn-btn cn-btn-primary" type="submit">Login</button>
    <p class="cn-empty" style="margin-top:1rem;">
      New here? <a href="/auth/register" style="text-decoration:underline;">Create an account</a>
    </p>
  </form>
</section>

