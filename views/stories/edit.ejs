<section class="cn-section">
    <div class="cn-section-header">
      <h2>Edit Story</h2>
      <a href="/stories/<%= story._id %>">Back</a>
    </div>
  
    <div class="cn-card">
      <div class="cn-card-body">
        <form
          class="cn-form"
          action="/stories/<%= story._id %>?_method=PUT"
          method="POST"
          enctype="multipart/form-data"
        >
          <label class="cn-label">Title</label>
          <input
            class="cn-input"
            type="text"
            name="title"
            value="<%= story.title %>"
            required
          />
  
          <label class="cn-label">Content</label>
          <textarea
            class="cn-textarea"
            name="content"
            required
          ><%= story.content %></textarea>
  
          <label class="cn-label">Change cover image (upload)</label>
          <input type="file" name="coverImageFile" />
  
          <label class="cn-label">Or image URL</label>
          <input
            class="cn-input"
            type="text"
            name="coverImageUrl"
            value="<%= story.coverImageUrl %>"
          />
  
          <label class="cn-label">Tags (comma separated)</label>
          <input
            class="cn-input"
            type="text"
            name="tags"
            value="<%= (story.tags || []).join(', ') %>"
          />
  
          <div style="margin-top:1rem;">
            <button class="cn-btn cn-btn-primary">Update Story</button>
          </div>
        </form>
      </div>
    </div>
  </section>
  