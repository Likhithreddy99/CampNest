<section class="cn-section">
  <div class="cn-section-header">
    <h2>Stories</h2>
    <% if (currentUser) { %>
      <a href="/stories/new">Write a story</a>
    <% } else { %>
      <a href="/auth/login">Login to write</a>
    <% } %>
  </div>

  <div class="cn-grid cn-grid-stories">
    <% if (stories && stories.length) { %>
      <% stories.forEach(story => { %>
        <article class="cn-card cn-card-story">
          <div class="cn-card-body">
            <h3><a href="/stories/<%= story._id %>"><%= story.title %></a></h3>
            <p class="cn-card-meta">
              by <%= story.author?.username || "unknown" %> · <%= story.createdAt.toLocaleDateString() %>
            </p>
            <p class="cn-card-snippet"><%= story.content.slice(0, 180) %>...</p>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <p class="cn-empty">No stories yet.</p>
    <% } %>
  </div>
</section>

