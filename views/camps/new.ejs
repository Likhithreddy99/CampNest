<section class="cn-section">
  <div class="cn-section-header">
    <h2>Post a campsite</h2>
    <a href="/camps">Back</a>
  </div>

  <form class="cn-form" action="/camps" method="POST" enctype="multipart/form-data">
    <label class="cn-label">Title</label>
    <input class="cn-input" name="title" type="text" placeholder="Sunrise Ridge Camp" required />

    <label class="cn-label">Location</label>
    <input class="cn-input" name="location" type="text" placeholder="Ooty, Tamil Nadu" required />

    <label class="cn-label">Upload image (optional)</label>
    <input class="cn-input" name="imageFile" type="file" accept="image/*" />

    <label class="cn-label">...or Image URL (optional)</label>
    <input class="cn-input" name="imageUrl" type="url" placeholder="https://..." />

    <label class="cn-label">Tags (comma separated)</label>
    <input class="cn-input" name="tags" type="text" placeholder="waterfall, forest, sunrise" />

    <label class="cn-label">Description</label>
    <textarea class="cn-textarea" name="description" placeholder="What’s it like? Tips? Safety?" required></textarea>

    <button class="cn-btn cn-btn-primary" type="submit">Publish</button>
  </form>
</section>

