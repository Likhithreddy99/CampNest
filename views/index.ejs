<section class="cn-hero">
  <div class="cn-hero-text">
    <h1>Find your next campsite. Share your camp stories.</h1>
    <p>
      CampNest is a cozy space for campers to discover hidden gems, review campsites, and blog about their
      adventures.
    </p>
    <div class="cn-hero-actions">
      <a href="/camps" class="cn-btn cn-btn-primary">Explore Campsites</a>
      <a href="/stories" class="cn-btn cn-btn-ghost">Read Stories</a>
    </div>
  </div>
  <div class="cn-hero-card">
    <h2>Why CampNest?</h2>
    <ul>
      <li>Authentic campsite reviews from real campers</li>
      <li>Live tips & updates from people on-site</li>
      <li>Long-form stories to inspire your next trip</li>
    </ul>
  </div>
</section>

<section class="cn-section">
  <div class="cn-section-header">
    <h2>Trending Campsites</h2>
    <a href="/camps">View all</a>
  </div>
  <div class="cn-grid">
    <% if (trendingCamps && trendingCamps.length) { %>
      <% trendingCamps.forEach(camp => { %>
        <article class="cn-card">
          <div class="cn-card-image" style="<%= camp.imageUrl ? `background-image:url('${camp.imageUrl}')` : '' %>"></div>
          <div class="cn-card-body">
            <h3><a href="/camps/<%= camp._id %>"><%= camp.title %></a></h3>
            <p class="cn-card-location"><%= camp.location %></p>
            <p class="cn-card-rating"><%= camp.averageRating.toFixed(1) %> ★</p>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <p class="cn-empty">No campsites yet. Be the first to post one!</p>
    <% } %>
  </div>
</section>

<section class="cn-section">
  <div class="cn-section-header">
    <h2>Latest Stories</h2>
    <a href="/stories">Read all</a>
  </div>
  <div class="cn-grid cn-grid-stories">
    <% if (latestStories && latestStories.length) { %>
      <% latestStories.forEach(story => { %>
        <article class="cn-card cn-card-story">
          <div class="cn-card-body">
            <h3><a href="/stories/<%= story._id %>"><%= story.title %></a></h3>
            <p class="cn-card-meta">
              by <%= story.author.username %> ·
              <%= story.createdAt.toLocaleDateString() %>
            </p>
            <p class="cn-card-snippet"><%= story.content.slice(0, 160) %>...</p>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <p class="cn-empty">No stories yet. Start the first campfire tale.</p>
    <% } %>
  </div>
</section>

